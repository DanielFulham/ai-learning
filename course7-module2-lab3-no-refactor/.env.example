# Copy to .env and fill in real values.
# .env is gitignored — never commit real keys.

# Required for any lab that uses OpenAI (e.g. `course7-module2-lab1-no-refactor/app.py`,
# `course7-module2-lab2-no-refactor/app.py`).
# Get a key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Required for any lab that uses Tavily web search (e.g. `course7-module2-lab2-no-refactor/app.py`).
# Get a key from https://app.tavily.com — free tier is 1,000 credits/month.
TAVILY_API_KEY=tvly-...